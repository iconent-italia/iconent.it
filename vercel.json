{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "cleanUrls": false,
  "redirects": [
    {
      "source": "/servizio-spotify/",
      "destination": "/spotify/",
      "permanent": true
    },
    {
      "source": "/servizi/",
      "destination": "/management/",
      "permanent": true
    },
    {
      "source": "/produzione-video/",
      "destination": "/management/",
      "permanent": true
    },
    {
      "source": "/distribuzione-major/",
      "destination": "/form-prenotazione/",
      "permanent": true
    },
    {
      "source": "/2019/:slug*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/2020/:slug*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about-us.html",
      "destination": "/chi-siamo/",
      "permanent": true
    },
    {
      "source": "/contact-us.html",
      "destination": "/contatti/",
      "permanent": true
    },
    {
      "source": "/servizi-spotify.html",
      "destination": "/spotify/",
      "permanent": true
    },
    {
      "source": "/servizi-youtube.html",
      "destination": "/youtube/",
      "permanent": true
    },
    {
      "source": "/servizi-instagram.html",
      "destination": "/instagram/",
      "permanent": true
    },
    {
      "source": "/servizi-tiktok.html",
      "destination": "/tiktok/",
      "permanent": true
    },
    {
      "source": "/servizi-project-management.html",
      "destination": "/management/",
      "permanent": true
    },
    {
      "source": "/chi-siamo.html",
      "destination": "/chi-siamo/",
      "permanent": true
    },
    {
      "source": "/contatti.html",
      "destination": "/contatti/",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/privacy/",
      "permanent": true
    },
    {
      "source": "/cookie.html",
      "destination": "/cookie/",
      "permanent": true
    },
    {
      "source": "/privacy-policy/",
      "destination": "/privacy/",
      "permanent": true
    },
    {
      "source": "/cookie-policy/",
      "destination": "/cookie/",
      "permanent": true
    }
  ]
}
