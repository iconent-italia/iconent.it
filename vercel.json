{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?<host>.*\\.vercel\\.app)"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/conceptwebsite/tonyeffe",
      "destination": "https://iconent-concept.vercel.app/concept/tony-effe/"
    },
    {
      "source": "/conceptwebsite/tonyeffe/",
      "destination": "https://iconent-concept.vercel.app/concept/tony-effe/"
    },
    {
      "source": "/concept/:path*",
      "destination": "https://iconent-concept.vercel.app/concept/:path*"
    },
    {
      "source": "/servizi-marketing",
      "destination": "https://iconent-servizi-marketing.vercel.app/servizi-marketing"
    },
    {
      "source": "/servizi-marketing/",
      "destination": "https://iconent-servizi-marketing.vercel.app/servizi-marketing/"
    },
    {
      "source": "/servizi-marketing/:path*",
      "destination": "https://iconent-servizi-marketing.vercel.app/servizi-marketing/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/concept/tony-effe/",
      "destination": "/conceptwebsite/tonyeffe/",
      "permanent": true
    },
    {
      "source": "/concept/tonyeffeconceptwebsite/",
      "destination": "/conceptwebsite/tonyeffe/",
      "permanent": true
    },
    {
      "source": "/tonyeffeconceptwebsite/",
      "destination": "/conceptwebsite/tonyeffe/",
      "permanent": true
    },
    {
      "source": "/tonyeffeconceptwebsite",
      "destination": "/conceptwebsite/tonyeffe/",
      "permanent": true
    },
    {
      "source": "/listino-marketing",
      "destination": "/servizi-marketing/",
      "permanent": true
    },
    {
      "source": "/listino-marketing/",
      "destination": "/servizi-marketing/",
      "permanent": true
    },
    {
      "source": "/listino-marketing/:path*",
      "destination": "/servizi-marketing/:path*",
      "permanent": true
    },
    {
